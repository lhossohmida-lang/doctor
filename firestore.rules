rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function userDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function hasRole(role) {
      return signedIn()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && userDoc().data.role == role;
    }

    function isAdmin() {
      return hasRole("admin");
    }

    function isWaitingScreen() {
      return hasRole("waiting_screen") || isAdmin();
    }

    match /users/{uid} {
      allow get: if signedIn() && (request.auth.uid == uid || isAdmin());
      allow list: if isAdmin();
      allow create, update, delete: if isAdmin();
    }

    match /dailyCounters/{date} {
      allow read, write: if isAdmin();
    }

    match /appointments/{date}/patients/{patientId} {
      allow read, write: if isAdmin();
    }

    match /publicQueue/{date} {
      allow get: if true;
      allow list: if false;
      allow write: if isAdmin();
    }

    match /publicTickets/{date}/tickets/{bookingCode} {
      allow get: if true;
      allow list: if false;
      allow write: if isAdmin();
    }

    match /publicLookups/{date}/phones/{phoneKey} {
      allow get: if true;
      allow list: if false;
      allow write: if isAdmin();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
