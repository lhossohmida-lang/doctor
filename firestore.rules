rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function userDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function hasRole(role) {
      return signedIn()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && userDoc().data.role == role;
    }

    function hasAdminEmail() {
      return signedIn()
        && request.auth.token.email != null
        && request.auth.token.email == "ma@ma.com";
    }

    function isAdmin() {
      return hasRole("admin") || hasAdminEmail();
    }

    function isPublicRegistration() {
      return true;
    }

    function publicAppointmentFields() {
      return [
        "patientId",
        "bookingCode",
        "fullName",
        "phone",
        "phoneKey",
        "queueNumber",
        "disease",
        "amountPaid",
        "paymentStatus",
        "status",
        "qrValue",
        "date",
        "source",
        "createdAt",
        "updatedAt"
      ];
    }

    function validPublicAppointmentCreate(date, patientId) {
      return isPublicRegistration()
        && request.resource.data.keys().hasOnly(publicAppointmentFields())
        && request.resource.data.patientId == patientId
        && request.resource.data.date == date
        && request.resource.data.fullName is string
        && request.resource.data.fullName.size() >= 3
        && request.resource.data.fullName.size() <= 80
        && request.resource.data.phone is string
        && request.resource.data.phoneKey is string
        && request.resource.data.phoneKey.matches("^[0-9]{6,18}$")
        && request.resource.data.bookingCode is string
        && request.resource.data.queueNumber is int
        && request.resource.data.queueNumber > 0
        && request.resource.data.disease is string
        && request.resource.data.disease.size() >= 2
        && request.resource.data.disease.size() <= 160
        && request.resource.data.amountPaid == 0
        && request.resource.data.paymentStatus == "unpaid"
        && request.resource.data.status == "waiting"
        && request.resource.data.source == "customer"
        && request.resource.data.qrValue is string
        && request.resource.data.createdAt == request.time
        && request.resource.data.updatedAt == request.time;
    }

    function validPublicQueueCounterCreate(date) {
      return isPublicRegistration()
        && request.resource.data.keys().hasOnly(["date", "lastNumber", "lastPatientId", "createdAt", "updatedAt"])
        && request.resource.data.date == date
        && request.resource.data.lastNumber is int
        && request.resource.data.lastNumber > 0
        && request.resource.data.lastPatientId is string
        && request.resource.data.createdAt == request.time
        && request.resource.data.updatedAt == request.time;
    }

    function validPublicQueueCounterUpdate() {
      return isPublicRegistration()
        && request.resource.data.keys().hasOnly(["date", "lastNumber", "lastPatientId", "createdAt", "updatedAt"])
        && request.resource.data.date == resource.data.date
        && request.resource.data.createdAt == resource.data.createdAt
        && request.resource.data.lastNumber > resource.data.lastNumber
        && request.resource.data.lastPatientId is string
        && request.resource.data.updatedAt == request.time;
    }

    function dailyCounterFields() {
      return ["date", "lastNumber", "currentCalledNumber", "currentPatientId", "createdAt", "updatedAt"];
    }

    function validPublicDailyCounterCreate(date) {
      return isPublicRegistration()
        && request.resource.data.keys().hasOnly(dailyCounterFields())
        && request.resource.data.date == date
        && request.resource.data.lastNumber is int
        && request.resource.data.lastNumber > 0
        && request.resource.data.currentCalledNumber is int
        && request.resource.data.currentCalledNumber >= 0
        && request.resource.data.currentPatientId == null
        && request.resource.data.createdAt == request.time
        && request.resource.data.updatedAt == request.time;
    }

    function validPublicDailyCounterUpdate() {
      return isPublicRegistration()
        && request.resource.data.keys().hasOnly(dailyCounterFields())
        && request.resource.data.date == resource.data.date
        && request.resource.data.createdAt == resource.data.createdAt
        && request.resource.data.currentCalledNumber == resource.data.currentCalledNumber
        && request.resource.data.currentPatientId == resource.data.currentPatientId
        && request.resource.data.lastNumber > resource.data.lastNumber
        && request.resource.data.updatedAt == request.time;
    }

    function validPublicTicketCreate(date, bookingCode) {
      return isPublicRegistration()
        && request.resource.data.keys().hasOnly([
          "patientId",
          "bookingCode",
          "fullName",
          "phoneKey",
          "queueNumber",
          "status",
          "qrValue",
          "date",
          "createdAt",
          "updatedAt"
        ])
        && request.resource.data.bookingCode == bookingCode
        && request.resource.data.date == date
        && request.resource.data.fullName is string
        && request.resource.data.fullName.size() >= 3
        && request.resource.data.fullName.size() <= 80
        && request.resource.data.phoneKey is string
        && request.resource.data.phoneKey.matches("^[0-9]{6,18}$")
        && request.resource.data.queueNumber is int
        && request.resource.data.status == "waiting"
        && request.resource.data.qrValue is string
        && request.resource.data.createdAt == request.time
        && request.resource.data.updatedAt == request.time;
    }

    function validPublicLookupWrite(phoneKey) {
      return isPublicRegistration()
        && request.resource.data.keys().hasOnly(["phoneKey", "bookingCodes", "lastBookingCode", "updatedAt"])
        && request.resource.data.phoneKey == phoneKey
        && request.resource.data.bookingCodes is list
        && request.resource.data.bookingCodes.size() <= 25
        && request.resource.data.lastBookingCode is string
        && request.resource.data.updatedAt == request.time;
    }

    function publicQueueFields() {
      return ["date", "currentCalledNumber", "lastNumber", "waitingCount", "nextNumber", "callToken", "updatedAt"];
    }

    function validPublicQueueCreate(date) {
      return isPublicRegistration()
        && request.resource.data.keys().hasOnly(publicQueueFields())
        && request.resource.data.date == date
        && request.resource.data.currentCalledNumber == 0
        && request.resource.data.lastNumber is int
        && request.resource.data.lastNumber > 0
        && request.resource.data.waitingCount is int
        && request.resource.data.waitingCount >= 1
        && request.resource.data.nextNumber == request.resource.data.lastNumber
        && request.resource.data.updatedAt == request.time;
    }

    function validPublicQueueUpdate() {
      return isPublicRegistration()
        && request.resource.data.keys().hasOnly(publicQueueFields())
        && request.resource.data.date == resource.data.date
        && request.resource.data.currentCalledNumber == resource.data.currentCalledNumber
        && request.resource.data.lastNumber > resource.data.lastNumber
        && request.resource.data.waitingCount is int
        && request.resource.data.waitingCount >= resource.data.waitingCount
        && (!("nextNumber" in resource.data) || resource.data.nextNumber == null || request.resource.data.nextNumber == resource.data.nextNumber)
        && (!("callToken" in resource.data) || request.resource.data.callToken == resource.data.callToken)
        && request.resource.data.updatedAt == request.time;
    }

    match /users/{uid} {
      allow get: if signedIn() && (request.auth.uid == uid || isAdmin());
      allow list: if isAdmin();
      allow create, update, delete: if isAdmin();
    }

    match /dailyCounters/{date} {
      allow read: if isAdmin();
      allow create: if isAdmin() || validPublicDailyCounterCreate(date);
      allow update: if isAdmin() || validPublicDailyCounterUpdate();
      allow delete: if isAdmin();
    }

    match /queueCounters/{date} {
      allow get: if true;
      allow list: if false;
      allow create: if isAdmin() || validPublicQueueCounterCreate(date);
      allow update: if isAdmin() || validPublicQueueCounterUpdate();
      allow delete: if isAdmin();
    }

    match /appointments/{date}/patients/{patientId} {
      allow read, update, delete: if isAdmin();
      allow create: if isAdmin() || validPublicAppointmentCreate(date, patientId);
    }

    match /publicQueue/{date} {
      allow get: if true;
      allow list: if false;
      allow create: if isAdmin() || validPublicQueueCreate(date);
      allow update: if isAdmin() || validPublicQueueUpdate();
      allow delete: if isAdmin();
    }

    match /publicTickets/{date}/tickets/{bookingCode} {
      allow get: if true;
      allow list: if false;
      allow create: if isAdmin() || validPublicTicketCreate(date, bookingCode);
      allow update, delete: if isAdmin();
    }

    match /publicLookups/{date}/phones/{phoneKey} {
      allow get: if true;
      allow list: if false;
      allow create, update: if isAdmin() || validPublicLookupWrite(phoneKey);
      allow delete: if isAdmin();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
